    "def plot_dashboard(price_paths, S0, shock_df, sent_df, composite, final_shock):\n",
    "    fig = plt.figure(figsize=(20, 16))\n",
    "    fig.patch.set_facecolor('#f9f9f9')\n",
    "    gs  = gridspec.GridSpec(2, 3, figure=fig, hspace=0.55, wspace=0.45)\n",
    "\n",
    "    ax_sim  = fig.add_subplot(gs[0, :2])\n",
    "    ax_hist = fig.add_subplot(gs[0, 2])\n",
    "    ax_dist = fig.add_subplot(gs[1, 0])\n",
    "    ax_sent = fig.add_subplot(gs[1, 1])\n",
    "    ax_info = fig.add_subplot(gs[1, 2])\n",
    "\n",
    "    days  = np.arange(price_paths.shape[0])\n",
    "    final = price_paths[-1, :]\n",
    "    p10   = np.percentile(price_paths, 10, axis=1)\n",
    "    p50   = np.percentile(price_paths, 50, axis=1)\n",
    "    p90   = np.percentile(price_paths, 90, axis=1)\n",
    "\n",
    "    # Panel 1: Monte Carlo paths\n",
    "    sample = np.random.choice(price_paths.shape[1], 120, replace=False)\n",
    "    for i in sample:\n",
    "        c = '#c0392b' if final[i] < p10[-1] else ('#1d9e75' if final[i] > p90[-1] else '#aaaaaa')\n",
    "        ax_sim.plot(days, price_paths[:, i], alpha=0.07, linewidth=0.6, color=c)\n",
    "    ax_sim.fill_between(days, p10, p90, alpha=0.12, color='#185fa5')\n",
    "    ax_sim.plot(days, p50, color='#185fa5', linewidth=2.5, label=f'Median ${p50[-1]:.0f}')\n",
    "    ax_sim.plot(days, p10, color='#c0392b', linewidth=1.5, linestyle='--', label=f'P10 ${p10[-1]:.0f}')\n",
    "    ax_sim.plot(days, p90, color='#1d9e75', linewidth=1.5, linestyle='--', label=f'P90 ${p90[-1]:.0f}')\n",
    "    ax_sim.axhline(S0, color='#555', linewidth=1, linestyle=':', label=f'Start ${S0:.0f}')\n",
    "    ax_sim.set_title(f'Monte Carlo Paths\\nCalibrated Shock: {final_shock:+.2%}  |  Sentiment: {composite:+.3f}', fontsize=11, pad=10)\n",
    "    ax_sim.set_xlabel('Trading Days', fontsize=10)\n",
    "    ax_sim.set_ylabel('Price (USD)', fontsize=10)\n",
    "    ax_sim.legend(fontsize=9, loc='upper left')\n",
    "    ax_sim.set_facecolor('white')\n",
    "    ax_sim.grid(alpha=0.2)\n",
    "\n",
    "    # Panel 2: Historical shocks\n",
    "    colors = ['#c0392b' if v < 0 else '#1d9e75' for v in shock_df['pct_change']]\n",
    "    y_pos  = np.arange(len(shock_df))\n",
    "    bars   = ax_hist.barh(y_pos, shock_df['pct_change'], color=colors, alpha=0.85,\n",
    "                          edgecolor='none', height=0.55)\n",
    "    for bar, val in zip(bars, shock_df['pct_change']):\n",
    "        ax_hist.text(val / 2, bar.get_y() + bar.get_height() / 2,\n",
    "                     f'{val:+.1f}%', va='center', ha='center',\n",
    "                     fontsize=8, color='white', fontweight='bold')\n",
    "    ax_hist.set_yticks(y_pos)\n",
    "    ax_hist.set_yticklabels(shock_df['event'], fontsize=8, linespacing=1.3)\n",
    "    ax_hist.axvline(0, color='#333', linewidth=0.8)\n",
    "    ax_hist.set_title('Real Historical AAPL Shocks', fontsize=11, pad=10)\n",
    "    ax_hist.set_xlabel('% price change during event', fontsize=9)\n",
    "    ax_hist.set_facecolor('white')\n",
    "    ax_hist.grid(alpha=0.2, axis='x')\n",
    "    ax_hist.set_xlim(left=shock_df['pct_change'].min() * 1.15)\n",
    "\n",
    "    # Panel 3: Final distribution\n",
    "    counts, edges, patches = ax_dist.hist(final, bins=40, edgecolor='none')\n",
    "    p10f, p90f = np.percentile(final, 10), np.percentile(final, 90)\n",
    "    for patch, left in zip(patches, edges[:-1]):\n",
    "        patch.set_facecolor('#c0392b' if left < p10f else ('#1d9e75' if left > p90f else '#185fa5'))\n",
    "        patch.set_alpha(0.75)\n",
    "    ax_dist.axvline(p50[-1], color='#185fa5', linewidth=2,   label=f'Median ${p50[-1]:.0f}')\n",
    "    ax_dist.axvline(S0,      color='#555',    linewidth=1.5, linestyle=':', label=f'Start ${S0:.0f}')\n",
    "    ax_dist.set_title('1-Year Final Price Distribution', fontsize=11, pad=10)\n",
    "    ax_dist.set_xlabel('Stock Price (USD)', fontsize=10)\n",
    "    ax_dist.set_ylabel('Simulations', fontsize=10)\n",
